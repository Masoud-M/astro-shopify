---
import ShopifyVariantSelector from "@components/Shopify/ShopifyVariantSelector.astro";
import BaseLayout from "./BaseLayout.astro";

const { productHandle, description, title } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="wrapper">
    <div class="product-layout">
      <div class="product-card">
        <shopify-context type="product" handle={productHandle}>
          <template>
            <div class="product-card__container">
              <div class="product-card__media">
                <div class="product-card__main-image">
                  <shopify-media
                    layout="constrained"
                    width="390"
                    height="490"
                    query="product.selectedOrFirstAvailableVariant.image"
                  ></shopify-media>
                </div>

                <div class="product-card__images">
                  <shopify-list-context
                    type="image"
                    query="product.selectedOrFirstAvailableVariant.product.images"
                    first="3"
                  >
                    <template>
                      <div class="product-card__image">
                        <shopify-media
                          class="product-card__image-large"
                          width="390"
                          height="490"
                          query="image"></shopify-media>
                        <shopify-media
                          class="product-card__image-small"
                          width="130"
                          height="150"
                          query="image"></shopify-media>
                      </div>
                    </template>
                  </shopify-list-context>
                </div>
              </div>
              <div class="product-card__details">
                <div class="product-card__info">
                  <div class="product-card__vendor">
                    <span class="product-card__vendor-text">
                      <shopify-data query="product.vendor"></shopify-data>
                    </span>
                  </div>
                  <h1 class="product-card__title">
                    <shopify-data query="product.title"></shopify-data>
                  </h1>
                  <div class="product-card__price">
                    <shopify-money
                      query="product.selectedOrFirstAvailableVariant.price"
                    ></shopify-money>
                    <shopify-money
                      class="product-card__compare-price"
                      query="product.selectedOrFirstAvailableVariant.compareAtPrice"
                    ></shopify-money>
                  </div>
                </div>

                <ShopifyVariantSelector
                  radioVariant="text"
                  colorSwatchVariant="circle"
                />

                <div class="product-card__buttons">
                  <!-- Add behavior to an existing button -->
                  <button
                    class="product-card__add-button"
                    onclick="getElementById('cart').addLine(event).showModal();"
                    shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale"
                  >
                    Add to cart
                  </button>

                  <!-- Add buy button -->
                  <button
                    class="product-card__buy-button"
                    onclick="document.querySelector('shopify-store').buyNow(event)"
                    class="product-buy-now__button"
                    shopify-attr--disabled="!product.selectedOrFirstAvailableVariant.availableForSale"
                  >
                    Buy now
                  </button>
                </div>

                <div class="product-card__description">
                  <span class="product-card__description-text">
                    <shopify-data query="product.description"></shopify-data>
                  </span>
                </div>
              </div>
            </div>
          </template>
          <!-- Placeholder -->
          <div class="contents placeholder">
            <div class="product-card__container">
              <div class="product-card__media">
                <div class="product-card__main-image">
                  <div class="skeleton-box" style="width: 420px; height: 420px">
                  </div>
                </div>
                <div class="product-card__images">
                  <div class="skeleton-box" style="width: 130px; height: 150px">
                  </div>
                  <div class="skeleton-box" style="width: 130px; height: 150px">
                  </div>
                  <div class="skeleton-box" style="width: 130px; height: 150px">
                  </div>
                </div>
              </div>
              <div class="product-card__details">
                <div class="skeleton-box" style="width: 100px; height: 94.5px">
                </div>
                <div class="skeleton-box" style="width: 287.4px; height: 142px">
                </div>
                <div
                  class="skeleton-box"
                  style="width: 287.4px; height: 53px; border-radius: 0.75rem"
                >
                </div>
              </div>
            </div>
          </div>
        </shopify-context>
      </div>
    </div>
  </section>
</BaseLayout>

<style lang="less">
  /*-- -------------------------------- -->
  <---     Product Details Page      -->
  <--- -------------------------------- -*/

  @media only screen and (min-width: 0rem) {
    .wrapper {
      margin-top: 100px;
      padding: var(--sectionPadding);
      margin-inline: auto;
      display: flex;
      justify-content: center;
    }

    .product-layout {
      width: 100%;
      max-width: (1280/16rem);
      margin: auto;
      display: flex;
      justify-content: center;
    }

    .product-card {
      width: 100%;
      min-width: 320px;
      background-color: var(--bodyTextColorWhite);
      border: 1px solid #e8e8e8;
      border-radius: (4/16rem);
      overflow: auto;
    }

    .product-card__container {
      display: flex;
      flex-direction: column;
      padding: (20/16rem);
      gap: (32/16rem);
      box-sizing: border-box;
    }

    .product-card__media {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
    }

    .product-card__main-image shopify-media img {
      border-radius: (4/16rem);
      transition: transform 0.3s ease;
    }

    .product-card__main-image:hover shopify-media img {
      transform: scale(1.02);
    }

    .product-card__images {
      display: flex;
      flex-wrap: wrap;
      position: relative;
      justify-content: center;
      gap: 8px;
      margin-top: 8px;
    }

    .product-card__image-small {
      cursor: pointer;
      transition: opacity 0.2s ease;
    }

    .product-card__image-small img:hover {
      opacity: 0.8;
    }

    .product-card__image-small img {
      width: 100%;
      height: auto;
      border-radius: 4px;
    }

    .product-card__images .product-card__image-large {
      display: block !important;
      position: absolute;
      transition: 200ms opacity ease-in;
      opacity: 0;
      top: 0;
      left: 50%;
      width: 390px;
      height: 490px;
      transform: translateX(-50%) translateY(calc(-100% - 8px));
      z-index: 1;
    }

    .product-card__image:hover .product-card__image-large {
      opacity: 1;
    }

    .product-card__images .product-card__image-large img {
      width: 100%;
      border-radius: 4px;
    }

    .product-card__details {
      display: flex;
      flex-direction: column;
      gap: (32/16rem);
      width: 100%;
    }

    .product-card__info {
      display: flex;
      flex-direction: column;
      gap: (8/16rem);
    }

    .product-card__vendor {
      display: flex;
      justify-content: space-between;
    }

    .product-card__vendor-text {
      opacity: 0.6;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      font-size: (12/16rem);
      color: var(--bodyTextColor);
    }

    .product-card__title {
      color: var(--headerColor);
      /* 28px - 36px */
      font-size: clamp(1.75rem, 2vw, 2.25rem);
      font-weight: 700;
      line-height: 1.2em;
      margin: 0;
    }

    .product-card__price {
      display: flex;
      gap: (12/16rem);
      font-weight: 700;
      /* 20px - 24px */
      font-size: clamp(1.25rem, 1.5vw, 1.5rem);
      color: var(--secondary);
    }

    .product-card__compare-price {
      text-decoration: line-through;
      font-weight: 700;
      font-size: (16/16rem);
      color: #767676;
      opacity: 0.8;
    }

    .product-card__description {
      display: flex;
      justify-content: space-between;
      padding-top: (24/16rem);
      border-top: 1px solid #e8e8e8;
    }

    .product-card__description-text {
      font-weight: 400;
      color: #767676;
      letter-spacing: 0.02em;
      font-size: (14/16rem);
      line-height: 1.6em;
    }

    .product-card__description-text p {
      margin: 0;
    }

    .product-card__buttons {
      display: flex;
      flex-direction: column;
      /* 12px - 16px */
      gap: clamp(0.75rem, 1vw, 1rem);
    }

    .product-card__buttons button {
      font-size: (14/16rem);
      font-weight: 700;
      line-height: 1.2em;
      text-transform: uppercase;
      cursor: pointer;
      transition:
        background-color 0.3s ease,
        color 0.3s ease,
        border-color 0.3s ease;
      border-radius: (4/16rem);
      padding: (12/16rem) (20/16rem);
      width: 100%;
    }

    .product-card__add-button {
      background-color: var(--primary);
      color: var(--headerColor);
      border: 2px solid var(--primary);

      &:hover {
        background-color: transparent;
        color: var(--primary);
      }
    }

    .product-card__add-button:disabled {
      opacity: 0.5;
      cursor: not-allowed;

      &:hover {
        background-color: var(--primary);
        color: var(--headerColor);
      }
    }

    .product-card__buy-button {
      background-color: transparent;
      color: var(--bodyTextColor);
      border: 2px solid var(--primary);

      &:hover {
        background-color: var(--primary);
        color: var(--headerColor);
      }
    }

    .product-card__buy-button:disabled {
      opacity: 0.5;
      cursor: not-allowed;

      &:hover {
        background-color: transparent;
        color: var(--bodyTextColor);
      }
    }

    shopify-variant-selector::part(radio) {
      padding: (8/16rem) (12/16rem);
      font-size: (14/16rem);
    }
  }

  /* Tablet - 768px */
  @media only screen and (min-width: 48rem) {
    .product-card__container {
      flex-direction: row;
      padding: (28/16rem);
      gap: clamp(2rem, 4vw, 3rem);
    }

    .product-card__media {
      width: 50%;
    }

    .product-card__details {
      width: 50%;
    }
  }

  /* Desktop - 1024px */
  @media only screen and (min-width: 64rem) {
    .product-card__container {
      padding: (40/16rem);
    }
  }

  /* Dark Mode */
  @media only screen and (min-width: 0rem) {
    body.dark-mode {
      .product-card {
        background-color: var(--medium);
        border-color: var(--accent);
      }

      .product-card__title,
      .product-card__vendor-text,
      .product-card__price {
        color: var(--bodyTextColorWhite);
      }

      .product-card__compare-price {
        color: var(--bodyTextColorWhite);
        text-decoration: line-through;
      }

      .product-card__description-text {
        color: var(--bodyTextColorWhite);
      }

      .product-card__description {
        border-top-color: var(--accent);
      }

      .product-card__image--selected .product-card__image-small img {
        border-color: var(--primary);
      }

      .product-card__buttons button {
        border-color: var(--primary);
      }

      .product-card__add-button {
        background-color: var(--primary);
        color: var(--headerColor);

        &:hover {
          background-color: transparent;
          color: var(--primary);
        }
      }

      .product-card__add-button:disabled {
        &:hover {
          background-color: var(--primary);
          color: var(--headerColor);
        }
      }

      .product-card__buy-button {
        color: var(--bodyTextColorWhite);

        &:hover {
          background-color: var(--primary);
          color: var(--headerColor);
        }
      }

      shopify-variant-selector::part(radio) {
        color: var(--bodyTextColorWhite);
      }
    }
  }
</style>

<style id="placeholder-css" lang="less">
  .skeleton-box {
    box-sizing: border-box;
    display: block;
    position: relative;
    background-color: #dddbdd;
    border-radius: (3/16rem);
    overflow: hidden;

    &::after {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      left: 0;
      transform: translateX(-100%);
      background-image: linear-gradient(
        90deg,
        rgba(255, 255, 255, 0) 0,
        rgba(255, 255, 255, 0.2) 20%,
        rgba(255, 255, 255, 0.5) 60%,
        rgba(255, 255, 255, 0)
      );
      animation: shimmer 5s infinite;
      content: "";
    }
  }

  @keyframes shimmer {
    0% {
      transform: translateX(-100%);
    }

    100% {
      transform: translateX(100%);
    }
  }

  shopify-context,
  .contents {
    display: contents;
  }

  shopify-context > .placeholder {
    opacity: 1;
    display: flex;
  }

  shopify-context > .placeholder.contents {
    display: contents;
  }

  shopify-context[shopify-content-loaded] > .placeholder.placeholder {
    opacity: 0;
    display: none;
  }

  shopify-context:has(> .placeholder) > :not(.placeholder, template) {
    opacity: 0;
    display: none;
    transition:
      opacity 0.5s ease,
      display 0.5s ease allow-discrete;
    transition-delay: 0.1s;
  }

  shopify-context:has(> .placeholder)[shopify-content-loaded]
    > :not(.placeholder, template) {
    opacity: 1;
    display: flex;
  }

  @starting-style {
    shopify-context:has(> .placeholder)[shopify-content-loaded]
      > :not(.placeholder, template) {
      opacity: 0;
    }
  }
</style>
